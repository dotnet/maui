<?xml version="1.0" encoding="utf-8" ?>
<!-- Test for Issue #28854: Background property replaces BackgroundColor -->
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Microsoft.Maui.Controls.Xaml.UnitTests.Maui28854">

    <!-- Label with Background set to a SolidColorBrush -->
    <VerticalStackLayout>
        <Label x:Name="labelSolidBrush">
            <Label.Background>
                <SolidColorBrush Color="Red" />
            </Label.Background>
        </Label>

        <Label x:Name="labelColorString"
               Background="Blue" />

        <BoxView x:Name="boxViewGradient">
            <BoxView.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Red" Offset="0" />
                    <GradientStop Color="Blue" Offset="1" />
                </LinearGradientBrush>
            </BoxView.Background>
        </BoxView>

        <Label x:Name="labelNoBackground" Text="No Background Set" />
    </VerticalStackLayout>
</ContentPage>

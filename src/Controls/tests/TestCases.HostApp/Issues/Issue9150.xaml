<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:issues="clr-namespace:Maui.Controls.Sample.Issues"
             x:Class="Maui.Controls.Sample.Issues.Issue9150">
    <VerticalStackLayout Padding="12,24"
                         Spacing="12">
        <Label Text="Picker SelectedIndex initialization" />
        <Picker x:Name="ItemsSourcePicker"
                AutomationId="ItemsSourcePicker"
                SelectedIndexChanged="OnSelectedIndexChanged"
                SelectedIndex="1"
                ItemsSource="{x:Static issues:Issue9150.StaticItems}" />
        <Picker x:Name="InlineItemsPicker"
                AutomationId="InlineItemsPicker"
                SelectedIndexChanged="OnSelectedIndexChanged"
                SelectedIndex="2">
            <Picker.Items>
                <x:String>Red</x:String>
                <x:String>Green</x:String>
                <x:String>Blue</x:String>
            </Picker.Items>
        </Picker>
        <Label x:Name="StatusLabel"
               AutomationId="StatusLabel" />
    </VerticalStackLayout>
</ContentPage>

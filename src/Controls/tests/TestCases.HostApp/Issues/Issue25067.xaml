<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       x:Class="Maui.Controls.Sample.Issues.Issue25067"
       >
  <ShellContent>
    <ContentPage
      Shell.NavBarIsVisible="true">

      <Shell.SearchHandler>
        <SearchHandler AutomationId="searchHandler" Query="search" SearchBoxVisibility="Expanded" />
      </Shell.SearchHandler>

      <StackLayout>
        <Label AutomationId="WaitForStubControl" Text="If you see a search icon (left) and clear icon (right) then the test passes."/>
      </StackLayout>
    </ContentPage>
  </ShellContent>
</Shell>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Maui.Controls.Sample"
             x:Class="Maui.Controls.Sample.Issues.Issue23014">
    <VerticalStackLayout x:Name="Stack"
                         Padding="30,0"
                         Spacing="25">
        <Label x:Name="StatusLabel"
               AutomationId="StatusLabel"
               Text="Waiting" />
        <Button AutomationId="ScrollToRemovedButton"
                Text="Remove CollectionView and ScrollTo"
                Clicked="OnRemoveAndScrollToClicked"
                HorizontalOptions="Fill"/>
        <local:CollectionView2 x:Name="ItemList"
                        AutomationId="ItemList"
                        ItemsSource="{Binding Items}">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="x:String">
                    <Border Stroke="Green"
                            Margin="2"
                            Padding="4">
                        <Label Text="{Binding}"/>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </local:CollectionView2>
    </VerticalStackLayout>
</ContentPage>

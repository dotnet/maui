                                                          Margin="0,5"/>
                                                 <Label Text="NAVIGATING EVENT"
                                                        FontSize="13"
                                                        FontAttributes="Bold"
                                                        TextColor="DarkBlue"/>
                                                 <Grid ColumnDefinitions="Auto,*"
                                                       RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                                       RowSpacing="2"
                                                       ColumnSpacing="8">
                                                        <Label Grid.Row="0"
                                                               Grid.Column="0"
                                                               Text="Current:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="0"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingCurrent}"
                                                               FontSize="11"
                                                               AutomationId="Page2NavigatingCurrentLabel"/>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="0"
                                                               Text="Source:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingSource}"
                                                               FontSize="11"
                                                               AutomationId="Page2NavigatingSourceLabel"/>
                                                        <Label Grid.Row="2"
                                                               Grid.Column="0"
                                                               Text="Target:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="2"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingTarget}"
                                                               FontSize="11"
                                                               AutomationId="Page2NavigatingTargetLabel"/>
                                                        <Label Grid.Row="3"
                                                               Grid.Column="0"
                                                               Text="CanCancel:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="3"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingCanCancel}"
                                                               FontSize="11"
                                                               AutomationId="Page2NavigatingCanCancelLabel"/>
                                                        <Label Grid.Row="4"
                                                               Grid.Column="0"
                                                               Text="Cancelled:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="4"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingCancelled}"
                                                               FontSize="11"
                                                               AutomationId="Page2NavigatingCancelledLabel"/>
                                                 </Grid>
                                                 <BoxView HeightRequest="1"
                                                          Color="Gray"
                                                          Margin="0,5"/>
                                                 <Label Text="NAVIGATED EVENT"
                                                        FontSize="13"
                                                        FontAttributes="Bold"
                                                        TextColor="DarkGreen"/>
                                                 <Grid ColumnDefinitions="Auto,*"
                                                       RowDefinitions="Auto,Auto,Auto"
                                                       RowSpacing="2"
                                                       ColumnSpacing="8">
                                                        <Label Grid.Row="0"
                                                               Grid.Column="0"
                                                               Text="Current:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="0"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatedCurrent}"
                                                               FontSize="11"
                                                               AutomationId="Page2NavigatedCurrentLabel"/>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="0"
                                                               Text="Previous:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatedPrevious}"
                                                               FontSize="11"
                                                               AutomationId="Page2NavigatedPreviousLabel"/>
                                                        <Label Grid.Row="2"
                                                               Grid.Column="0"
                                                               Text="Source:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="2"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatedSource}"
                                                               FontSize="11"
                                                               AutomationId="Page2NavigatedSourceLabel"/>
                                                 </Grid>
                                                 <Button Text="Go to Main"
                                                         AutomationId="GoToMainButton"
                                                         Clicked="OnGoToMainClicked"
                                                         Margin="0,10,0,0"/>
                                          </VerticalStackLayout>
                                   </ScrollView>
                            </ContentPage>
                     </ShellContent>
              </Tab>
              <Tab Title="TabB"
                   Route="TabB"
                   AutomationId="TabB">
                     <ShellContent Title="ContentB1"
                                   Route="ContentB1"
                                   AutomationId="ContentB1">
                            <ContentPage Title="Page2TabBContentB1"
                                         x:Name="Page2TabBPage"
                                         AutomationId="Page2TabBPage">
                                   <ScrollView>
                                          <VerticalStackLayout Padding="10"
                                                               Spacing="5">
                                                 <Label Text="Page 2 - Tab B"
                                                        FontSize="14"
                                                        FontAttributes="Bold"
                                                        AutomationId="Page2TabBPageLabel"/>

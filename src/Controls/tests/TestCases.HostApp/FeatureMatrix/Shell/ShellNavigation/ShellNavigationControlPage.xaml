                                                               Grid.Column="0"
                                                               Text="CurrentState:"
                                                               FontSize="12"/>
                                                        <Label Grid.Row="0"
                                                               Grid.Column="1"
                                                               FontSize="12"
                                                               AutomationId="Page2CurrentStateLabel"
                                                               x:Name="Page2CurrentStateLabel"/>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="0"
                                                               Text="CurrentPage:"
                                                               FontSize="12"/>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="1"
                                                               FontSize="12"
                                                               AutomationId="Page2CurrentPageLabel"
                                                               x:Name="Page2CurrentPageLabel"/>
                                                        <Label Grid.Row="2"
                                                               Grid.Column="0"
                                                               Text="CurrentItem:"
                                                               FontSize="12"/>
                                                        <Label Grid.Row="2"
                                                               Grid.Column="1"
                                                               FontSize="12"
                                                               AutomationId="Page2CurrentItemLabel"
                                                               x:Name="Page2CurrentItemLabel"/>
                                                        <Label Grid.Row="3"
                                                               Grid.Column="0"
                                                               Text="Shell.Current:"
                                                               FontSize="12"/>
                                                        <Label Grid.Row="3"
                                                               Grid.Column="1"
                                                               FontSize="12"
                                                               AutomationId="Page2ShellCurrentLabel"

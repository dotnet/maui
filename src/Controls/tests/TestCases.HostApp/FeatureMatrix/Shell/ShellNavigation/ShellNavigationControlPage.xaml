       <FlyoutItem Title="Page3"
                   Route="page3"
                   AutomationId="Page3">
              <!-- Page3: one Tab with two ShellContent items -->
              <!-- Both ShellContents share one ShellSection; switching triggers ShellContentChanged -->
              <Tab Title="Content"
                   Route="Content"
                   AutomationId="Content">
              <ShellContent Title="Content1"
                            Route="Content1"
                            AutomationId="Content1">

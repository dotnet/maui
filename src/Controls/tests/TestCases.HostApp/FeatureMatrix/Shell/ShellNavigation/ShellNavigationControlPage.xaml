                                                          Margin="0,5"/>
                                                 <Label Text="NAVIGATING EVENT"
                                                        FontSize="13"
                                                        FontAttributes="Bold"
                                                        TextColor="DarkBlue"/>
                                                 <Grid ColumnDefinitions="Auto,*"
                                                       RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                                       RowSpacing="2"
                                                       ColumnSpacing="8">
                                                        <Label Grid.Row="0"
                                                               Grid.Column="0"
                                                               Text="Current:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="0"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingCurrent}"
                                                               FontSize="11"
                                                               AutomationId="Page2TabBNavigatingCurrentLabel"/>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="0"
                                                               Text="Source:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="1"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingSource}"
                                                               FontSize="11"
                                                               AutomationId="Page2TabBNavigatingSourceLabel"/>
                                                        <Label Grid.Row="2"
                                                               Grid.Column="0"
                                                               Text="Target:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="2"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingTarget}"
                                                               FontSize="11"
                                                               AutomationId="Page2TabBNavigatingTargetLabel"/>
                                                        <Label Grid.Row="3"
                                                               Grid.Column="0"
                                                               Text="CanCancel:"
                                                               FontSize="11"/>
                                                        <Label Grid.Row="3"
                                                               Grid.Column="1"
                                                               Text="{Binding NavigatingCanCancel}"
                                                               FontSize="11"
                                                               AutomationId="Page2TabBNavigatingCanCancelLabel"/>
                                                        <Label Grid.Row="4"

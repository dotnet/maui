                                                 <Label Grid.Row="2"
                                                        Grid.Column="1"
                                                        Text="{Binding NavigatingTarget}"
                                                        FontSize="11"
                                                        AutomationId="Page3C1NavigatingTargetLabel"/>
                                                 <Label Grid.Row="3"
                                                        Grid.Column="0"
                                                        Text="CanCancel:"
                                                        FontSize="11"/>
                                                 <Label Grid.Row="3"
                                                        Grid.Column="1"
                                                        Text="{Binding NavigatingCanCancel}"
                                                        FontSize="11"
                                                        AutomationId="Page3C1NavigatingCanCancelLabel"/>
                                                 <Label Grid.Row="4"
                                                        Grid.Column="0"
                                                        Text="Cancelled:"

<?xml version="1.0" encoding="utf-8" ?>
<Shell
       xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:Maui.Controls.Sample"
       x:Class="Maui.Controls.Sample.ShellNavigationControlPage"
       x:DataType="local:ShellViewModel"
       x:Name="MainShell"
       Title="ShellNavigation"
       AutomationId="ShellNavigationMatrix">
       <FlyoutItem Title="Main"
                   Route="main"
                   AutomationId="Main">
              <ShellContent Title="Main"
                            Route="MainContent"
                            AutomationId="Main">
                     <ContentPage Title="ShellNavigation"
                                  x:Name="MainContentPage"
                                  AutomationId="MainContentPage">
                            <ContentPage.ToolbarItems>
                                   <ToolbarItem Text="Reset"
                                                Clicked="OnResetClicked"
                                                AutomationId="Reset"/>
                                   <ToolbarItem Text="Apply"
                                                Clicked="NavigateToOptionsPage_Clicked"
                                                AutomationId="Apply"/>
                            </ContentPage.ToolbarItems>
                            <ScrollView>
                                   <VerticalStackLayout Padding="0"
                                                        Spacing="0">
                                          <Label Text="Main Page"
                                                 FontSize="14"
                                                 FontAttributes="Bold"
                                                 Margin="10,8,10,4"
                                                 AutomationId="MainPageIdentityLabel"/>
                                          <Grid Padding="10"
                                                RowSpacing="4"
                                                ColumnSpacing="10"
                                                RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
                                                ColumnDefinitions="*,*">
                                                 <Label Grid.Row="0"
                                                        Grid.Column="0"
                                                        Text="CurrentState:"
                                                        FontSize="12"/>
                                                 <Label Grid.Row="0"
                                                        Grid.Column="1"
                                                        Text="{Binding CurrentState}"
                                                        FontSize="12"
                                                        AutomationId="CurrentStateLabel"/>
                                                 <Label Grid.Row="1"
                                                        Grid.Column="0"
                                                        Text="CurrentPage:"
                                                        FontSize="12"/>
                                                 <Label Grid.Row="1"
                                                        Grid.Column="1"
                                                        Text="{Binding CurrentPage}"
                                                        FontSize="12"
                                                        AutomationId="CurrentPageLabel"/>
                                                 <Label Grid.Row="2"
                                                        Grid.Column="0"
                                                        Text="CurrentItem:"
                                                        FontSize="12"/>
                                                 <Label Grid.Row="2"
                                                        Grid.Column="1"
                                                        Text="{Binding CurrentItem}"
                                                        FontSize="12"
                                                        AutomationId="CurrentItemLabel"/>
                                                 <Label Grid.Row="3"
                                                        Grid.Column="0"
                                                        Text="Shell.Current:"
                                                        FontSize="12"/>
                                                 <Label Grid.Row="3"
                                                        Grid.Column="1"
                                                        Text="{Binding ShellCurrent}"
                                                        FontSize="12"
                                                        AutomationId="ShellCurrentLabel"/>
                                                 <Label Grid.Row="4"
                                                        Grid.Column="0"
                                                        Text="TextOverride:"
                                                        FontSize="12"
                                                        VerticalOptions="Center"/>
                                                 <Entry Grid.Row="4"
                                                        Grid.Column="1"
                                                        Text="{Binding TextOverride}"
                                                        FontSize="12"
                                                        HeightRequest="35"
                                                        AutomationId="TextOverrideEntry"/>
                                                 <Label Grid.Row="5"
                                                        Grid.Column="0"
                                                        Text="IconOverride:"
                                                        FontSize="12"
                                                        VerticalOptions="Center"/>
                                                 <HorizontalStackLayout Grid.Row="5"
                                                                        Grid.Column="1"
                                                                        Spacing="5">
                                                        <Button Text="bank.png"
                                                                Clicked="OnIconOverrideClicked"
                                                                FontSize="10"
                                                                HeightRequest="30"
                                                                Padding="5,0"
                                                                AutomationId="IconOverrideBank"/>
                                                        <Button Text="coffee.png"
                                                                Clicked="OnIconOverrideClicked"
                                                                FontSize="10"
                                                                HeightRequest="30"
                                                                Padding="5,0"
                                                                AutomationId="IconOverrideCoffee"/>
                                                        <Button Text="None"
                                                                Clicked="OnIconOverrideClicked"
                                                                FontSize="10"
                                                                HeightRequest="30"
                                                                Padding="5,0"
                                                                AutomationId="IconOverrideDefault"/>
                                                 </HorizontalStackLayout>
                                                 <Button Grid.Row="6"
                                                         Grid.Column="0"
                                                         Text="{Binding IsEnabledText}"
                                                         FontSize="11"
                                                         HeightRequest="35"
                                                         Padding="5,0"
                                                         Clicked="OnToggleIsEnabled"
                                                         AutomationId="IsEnabledButton"/>
                                                 <Button Grid.Row="6"
                                                         Grid.Column="1"
                                                         Text="{Binding IsVisibleText}"
                                                         FontSize="11"
                                                         HeightRequest="35"
                                                         Padding="5,0"
                                                         Clicked="OnToggleIsVisible"
                                                         AutomationId="IsVisibleButton"/>
                                                 <Label Grid.Row="7"
                                                        Grid.Column="0"
                                                        Text="CommandParameter:"
                                                        FontSize="12"
                                                        VerticalOptions="Center"/>
                                                 <Entry Grid.Row="7"
                                                        Grid.Column="1"
                                                        Text="{Binding CommandParameter}"
                                                        FontSize="12"
                                                        HeightRequest="35"
                                                        AutomationId="CommandParameterEntry"/>
                                                 <Label Grid.Row="8"
                                                        Grid.Column="0"
                                                        Text="CommandExecuted:"
                                                        FontSize="12"/>
                                                 <Label Grid.Row="8"
                                                        Grid.Column="1"
                                                        Text="{Binding CommandExecuted}"
                                                        FontSize="12"
                                                        AutomationId="CommandExecutedLabel"/>
                                                 <Button Grid.Row="9"
                                                         Grid.Column="0"
                                                         Text="GoTo Detail1"
                                                         FontSize="12"
                                                         HeightRequest="35"
                                                         Padding="5,0"
                                                         Clicked="OnNavigateToDetail1Clicked"
                                                         AutomationId="NavigateToDetail1Button"/>
                                                 <Button Grid.Row="9"
                                                         Grid.Column="1"
                                                         Text="GoTo Detail2"
                                                         FontSize="12"
                                                         HeightRequest="35"
                                                         Padding="5,0"
                                                         Clicked="OnNavigateToDetail2Clicked"
                                                         AutomationId="NavigateToDetail2Button"/>
                                                 <Button Grid.Row="10"
                                                         Grid.Column="0"
                                                         Grid.ColumnSpan="2"
                                                         x:Name="ToggleRouteButton"
                                                         Text="Unregister Route"
                                                         FontSize="11"
                                                         HeightRequest="35"
                                                         Padding="5,0"
                                                         Clicked="OnToggleRouteClicked"
                                                         AutomationId="ToggleRouteButton"/>
                                                 <Label Grid.Row="11"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="2"
                                                        Text="{Binding RouteStatus}"
                                                        FontSize="11"
                                                        AutomationId="RouteStatusLabel"/>
                                                 <Button Grid.Row="12"
                                                         Grid.Column="0"
                                                         Text="{Binding CancelNavigationText}"
                                                         FontSize="11"
                                                         HeightRequest="35"
                                                         Padding="5,0"
                                                         Clicked="OnToggleCancelNavigation"
                                                         AutomationId="CancelNavigationButton"/>
                                                 <Button Grid.Row="12"
                                                         Grid.Column="1"
                                                         Text="{Binding EnableDeferralText}"
                                                         FontSize="11"
                                                         HeightRequest="35"
                                                         Padding="5,0"
                                                         Clicked="OnToggleEnableDeferral"
                                                         AutomationId="EnableDeferralButton"/>
                                                 <Label Grid.Row="13"
                                                        Grid.Column="0"
                                                        Grid.ColumnSpan="2"
                                                        Text="{Binding DeferralStatus}"
                                                        FontSize="11"
                                                        AutomationId="DeferralStatusLabel"/>
                                                 <Label Grid.Row="14"
                                                        Grid.Column="0"
                                                        Text="OnNavigating:"
                                                        FontSize="11"/>
                                                 <Label Grid.Row="14"
                                                        Grid.Column="1"
                                                        Text="{Binding OverrideNavigatingStatus}"
                                                        FontSize="10"
                                                        AutomationId="OverrideNavigatingLabel"/>
                                                 <Label Grid.Row="15"
                                                        Grid.Column="0"
                                                        Text="OnNavigated:"
                                                        FontSize="11"/>
                                                 <Label Grid.Row="15"
                                                        Grid.Column="1"
                                                        Text="{Binding OverrideNavigatedStatus}"
                                                        FontSize="10"
                                                        AutomationId="OverrideNavigatedLabel"/>
                                                 <Label Grid.Row="16"
                                                        Grid.Column="0"
                                                        Text="Cancelled:"
                                                        FontSize="11"/>
                                                 <Label Grid.Row="16"
                                                        Grid.Column="1"
                                                        Text="{Binding NavigatingCancelled}"
                                                        FontSize="11"
                                                        AutomationId="NavigatingCancelledLabel"/>
                                                 <Button Grid.Row="17"
                                                         Grid.Column="0"
                                                         Grid.ColumnSpan="2"
                                                         Text="Open Pass Data Demo"
                                                         FontSize="11"
                                                         HeightRequest="35"
                                                         Padding="5,0"
                                                         Clicked="OnOpenPassDataDemoClicked"
                                                         AutomationId="OpenPassDataDemoButton"/>
                                          </Grid>
                                   </VerticalStackLayout>
                            </ScrollView>
                     </ContentPage>
              </ShellContent>
       </FlyoutItem>
       <FlyoutItem Title="Page2"
                   Route="page2"
                   AutomationId="Page2">

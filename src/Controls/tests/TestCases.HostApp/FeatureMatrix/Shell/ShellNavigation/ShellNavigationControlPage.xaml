                                                 <Label Text="NAVIGATED EVENT"
                                                        FontSize="13"
                                                        FontAttributes="Bold"
                                                        TextColor="DarkGreen"/>
                                                 <Grid ColumnDefinitions="Auto,*"
                                                       RowDefinitions="Auto,Auto,Auto"
                                                       RowSpacing="2"

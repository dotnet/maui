<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
        xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
        xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
        xmlns:local="clr-namespace:Maui.Controls.Sample"
        x:Class="Maui.Controls.Sample.ShellNavigationOptionsPage"
        x:DataType="local:ShellViewModel"
        Title="OptionsPage"
        AutomationId="ShellNavigationOptionsPage">
        <Shell.BackButtonBehavior>
                <BackButtonBehavior
                        TextOverride="{Binding TextOverride}"
                        IconOverride="{Binding IconOverride}"
                        IsEnabled="{Binding IsEnabled}"
                        IsVisible="{Binding IsVisible}"
                        Command="{Binding Command}"
                        CommandParameter="{Binding CommandParameter}"/>
        </Shell.BackButtonBehavior>
        <ScrollView>
                <VerticalStackLayout Padding="6"
                                Spacing="3">
                        <Label Text="Options Page"
                               FontSize="12"
                               FontAttributes="Bold"
                               Margin="0,0,0,2"
                               AutomationId="OptionsPageIdentityLabel"/>
                        <Grid RowSpacing="2"
                              ColumnSpacing="8"
                              RowDefinitions="Auto,Auto,Auto,Auto"
                              ColumnDefinitions="*,*">
                                <Label Grid.Row="0"
                                       Grid.Column="0"
                                       Text="CurrentState:"
                                       FontSize="12"/>
                                <Label Grid.Row="0"
                                       Grid.Column="1"
                                       Text="{Binding CurrentState}"
                                       FontSize="12"
                                       AutomationId="OptionsCurrentStateLabel"/>
                                <Label Grid.Row="1"
                                       Grid.Column="0"
                                       Text="CurrentPage:"
                                       FontSize="12"/>
                                <Label Grid.Row="1"
                                       Grid.Column="1"
                                       Text="{Binding CurrentPage}"
                                       FontSize="12"
                                       AutomationId="OptionsCurrentPageLabel"/>
                                <Label Grid.Row="2"
                                       Grid.Column="0"
                                       Text="CurrentItem:"
                                       FontSize="12"/>
                                <Label Grid.Row="2"
                                       Grid.Column="1"
                                       Text="{Binding CurrentItem}"
                                       FontSize="12"
                                       AutomationId="OptionsCurrentItemLabel"/>
                                <Label Grid.Row="3"
                                       Grid.Column="0"
                                       Text="Shell.Current:"
                                       FontSize="12"/>
                                <Label Grid.Row="3"
                                       Grid.Column="1"
                                       Text="{Binding ShellCurrent}"
                                       FontSize="12"
                                       AutomationId="OptionsShellCurrentLabel"/>
                        </Grid>
                        <BoxView HeightRequest="1"
                                        Color="Gray"
                                        Margin="0,2"/>
                        <!-- Navigating Event -->
                        <Label Text="NAVIGATING EVENT"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="DarkBlue"/>
                        <Grid ColumnDefinitions="Auto,*"
                                        RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                                        RowSpacing="1"
                                        ColumnSpacing="8">
                                <Label Grid.Row="0"
                                                Grid.Column="0"
                                                Text="Current:"
                                                FontSize="12"/>
                                <Label Grid.Row="0"
                                                Grid.Column="1"
                                                Text="{Binding NavigatingCurrent}"
                                                FontSize="12"
                                       AutomationId="OptionsNavigatingCurrentLabel"/>
                                <Label Grid.Row="1"
                                                Grid.Column="0"
                                                Text="Source:"
                                                FontSize="12"/>
                                <Label Grid.Row="1"
                                                Grid.Column="1"
                                                Text="{Binding NavigatingSource}"
                                                FontSize="12"
                                       AutomationId="OptionsNavigatingSourceLabel"/>
                                <Label Grid.Row="2"
                                                Grid.Column="0"
                                                Text="Target:"
                                                FontSize="12"/>
                                <Label Grid.Row="2"
                                                Grid.Column="1"
                                                Text="{Binding NavigatingTarget}"
                                                FontSize="12"
                                       AutomationId="OptionsNavigatingTargetLabel"/>
                                <Label Grid.Row="3"
                                                Grid.Column="0"
                                                Text="CanCancel:"
                                                FontSize="12"/>
                                <Label Grid.Row="3"
                                                Grid.Column="1"
                                                Text="{Binding NavigatingCanCancel}"
                                                FontSize="12"
                                       AutomationId="OptionsNavigatingCanCancelLabel"/>
                                <Label Grid.Row="4"
                                                Grid.Column="0"
                                                Text="Cancelled:"
                                                FontSize="12"/>
                                <Label Grid.Row="4"
                                                Grid.Column="1"
                                                Text="{Binding NavigatingCancelled}"
                                                FontSize="12"
                                       AutomationId="OptionsNavigatingCancelledLabel"/>
                        </Grid>
                        <BoxView HeightRequest="1"
                                        Color="Gray"
                                        Margin="0,2"/>
                        <!-- Navigated Event -->
                        <Label Text="NAVIGATED EVENT"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="DarkGreen"/>
                        <Grid ColumnDefinitions="Auto,*"
                                        RowDefinitions="Auto,Auto,Auto"
                                        RowSpacing="1"
                                        ColumnSpacing="8">
                                <Label Grid.Row="0"
                                                Grid.Column="0"
                                                Text="Current:"
                                                FontSize="12"/>
                                <Label Grid.Row="0"
                                                Grid.Column="1"
                                                Text="{Binding NavigatedCurrent}"
                                                FontSize="12"
                                       AutomationId="OptionsNavigatedCurrentLabel"/>
                                <Label Grid.Row="1"
                                                Grid.Column="0"
                                                Text="Previous:"
                                                FontSize="12"/>
                                <Label Grid.Row="1"
                                                Grid.Column="1"
                                                Text="{Binding NavigatedPrevious}"
                                                FontSize="12"
                                       AutomationId="OptionsNavigatedPreviousLabel"/>
                                <Label Grid.Row="2"
                                                Grid.Column="0"
                                                Text="Source:"
                                                FontSize="12"/>
                                <Label Grid.Row="2"
                                                Grid.Column="1"
                                                Text="{Binding NavigatedSource}"
                                                FontSize="12"
                                       AutomationId="OptionsNavigatedSourceLabel"/>
                        </Grid>
                        <BoxView HeightRequest="1"
                                        Color="Gray"
                                        Margin="0,2"/>
                        <!-- Navigation Stack -->
                        <Label Text="NAVIGATION STACK"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="DarkOrange"/>
                        <Grid ColumnDefinitions="Auto,*"
                                        RowDefinitions="Auto,Auto"
                                        RowSpacing="1"
                                        ColumnSpacing="8">
                                <Label Grid.Row="0"
                                                Grid.Column="0"
                                                Text="Tab.Stack:"
                                                FontSize="12"/>
                                <Label Grid.Row="0"
                                                Grid.Column="1"
                                                FontSize="11"
                                       x:Name="TabStackLabel"
                                                AutomationId="OptionsTabStackLabel"/>
                                <Label Grid.Row="1"
                                                Grid.Column="0"
                                                Text="NavigationStack:"
                                                FontSize="12"/>
                                <Label Grid.Row="1"
                                                Grid.Column="1"
                                                FontSize="11"
                                       x:Name="GetNavStackLabel"
                                                AutomationId="OptionsGetNavStackLabel"/>
                        </Grid>
                        <BoxView HeightRequest="1"
                                        Color="Gray"
                                        Margin="0,2"/>
                        <!-- Tab Navigation Methods -->
                        <Label Text="TAB NAVIGATION METHODS"
                                        FontSize="11"
                                        FontAttributes="Bold"
                                        TextColor="DarkMagenta"/>
                        <Grid ColumnDefinitions="*,*"
                                        RowDefinitions="Auto,Auto,Auto"
                                        RowSpacing="3"
                                        ColumnSpacing="4">
                                <Button Grid.Row="0"
                                                Grid.Column="0"
                                                Text="OnPushAsync"
                                                FontSize="11"
                                                HeightRequest="30"
                                        Clicked="OnPushClicked"
                                                AutomationId="OptionsPushButton"/>
                                <Button Grid.Row="0"
                                                Grid.Column="1"
                                                Text="OnPopAsync"
                                                FontSize="11"
                                                HeightRequest="30"
                                        Clicked="OnPopClicked"
                                                AutomationId="OptionsPopButton"/>
                                <Button Grid.Row="1"
                                                Grid.Column="0"
                                                Text="OnPopToRootAsync"
                                                FontSize="11"
                                                HeightRequest="30"
                                        Clicked="OnPopToRootClicked"
                                                AutomationId="OptionsPopToRootButton"/>
                                <Button Grid.Row="1"
                                                Grid.Column="1"
                                                Text="OnInsertPageBefore"
                                                FontSize="11"
                                                HeightRequest="30"
                                        Clicked="OnInsertClicked"
                                                AutomationId="OptionsInsertButton"/>
                                <Button Grid.Row="2"
                                                Grid.Column="0"
                                                Grid.ColumnSpan="2"
                                                Text="OnRemovePage"
                                                FontSize="11"
                                                HeightRequest="30"
                                        Clicked="OnRemoveClicked"
                                                AutomationId="OptionsRemoveButton"/>
                        </Grid>
                </VerticalStackLayout>
        </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<Shell xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
       xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
       xmlns:local="clr-namespace:Maui.Controls.Sample"
       x:Class="Maui.Controls.Sample.ShellSearchControlPage"
       x:DataType="local:ShellViewModel"
       x:Name="MainShell"
       Title="ShellSearch"
       AutomationId="ShellSearchMatrix">
       <ShellContent Title="Search"
                     Route="search"
                     AutomationId="SearchTab">
              <ContentPage Title="ShellSearch"
                           x:Name="SearchContentPage"
                           AutomationId="SearchContentPage">
                     <Shell.SearchHandler>
                            <local:SampleSearchHandler x:Name="SearchHandlerInstance"
                                                       AutomationId="SearchHandler"
                                                       BackgroundColor="{Binding BackgroundColor}"
                                                       CancelButtonColor="{Binding CancelButtonColor}"
                                                       CharacterSpacing="{Binding CharacterSpacing}"
                                                       ClearIcon="{Binding ClearIcon}"
                                                       ClearPlaceholderCommandParameter="{Binding ClearPlaceholderCommandParameter}"
                                                       ClearPlaceholderEnabled="{Binding ClearPlaceholderEnabled}"
                                                       ClearPlaceholderCommand="{Binding ClearPlaceholderCommand}"
                                                       ClearPlaceholderIcon="{Binding ClearPlaceholderIcon}"
                                                       Command="{Binding SearchCommand}"
                                                       CommandParameter="{Binding CommandParameter}"
                                                       FontAttributes="{Binding FontAttributes}"
                                                       FontSize="{Binding FontSize}"
                                                       FontFamily="{Binding FontFamily}"
                                                       FontAutoScalingEnabled="{Binding FontAutoScalingEnabled}"
                                                       HorizontalTextAlignment="{Binding HorizontalTextAlignment}"
                                                       IsSearchEnabled="{Binding IsSearchEnabled}"
                                                       Keyboard="{Binding Keyboard}"
                                                       Placeholder="{Binding Placeholder}"
                                                       PlaceholderColor="{Binding PlaceholderColor}"
                                                       QueryIcon="{Binding QueryIcon}"
                                                       Query="{Binding Query}"
                                                       ShowsResults="{Binding ShowsResults}"
                                                       SearchBoxVisibility="{Binding SearchBoxVisibility}"
                                                       SelectedItem="{Binding SelectedItem}"
                                                       TextColor="{Binding TextColor}"
                                                       TextTransform="{Binding TextTransform}"
                                                       VerticalTextAlignment="{Binding VerticalTextAlignment}"/>
                     </Shell.SearchHandler>
                     <ContentPage.ToolbarItems>
                            <ToolbarItem Text="Options"
                                         Clicked="OnOptionsClicked"
                                         AutomationId="Options"/>
                     </ContentPage.ToolbarItems>
                     <ScrollView>
                            <VerticalStackLayout Padding="10,8"
                                                 Spacing="6">

                                   <!-- Action buttons -->
                                   <Grid RowSpacing="6"
                                         ColumnSpacing="8"
                                         RowDefinitions="Auto,Auto,Auto,Auto"
                                         ColumnDefinitions="*,*">
                                          <Button Grid.Row="0"
                                                  Grid.Column="0"
                                                  Text="Focus"
                                                  Clicked="OnFocusClicked"
                                                  AutomationId="FocusButton"/>
                                          <Button Grid.Row="0"
                                                  Grid.Column="1"
                                                  Text="Unfocus"
                                                  Clicked="OnUnfocusClicked"
                                                  AutomationId="UnfocusButton"/>
                                          <Button Grid.Row="1"
                                                  Grid.Column="0"
                                                  Text="ShowSoftInput"
                                                  Clicked="OnShowSoftInputClicked"
                                                  AutomationId="ShowSoftInputButton"/>
                                          <Button Grid.Row="1"
                                                  Grid.Column="1"
                                                  Text="HideSoftInput"
                                                  Clicked="OnHideSoftInputClicked"
                                                  AutomationId="HideSoftInputButton"/>
                                          <Button Grid.Row="2"
                                                  Grid.ColumnSpan="2"
                                                  Text="SetQuery:Robin"
                                                  Clicked="OnSetQueryClicked"
                                                  AutomationId="SetQueryButton"/>
                                          <Button Grid.Row="3"
                                                  Grid.ColumnSpan="2"
                                                  Text="TriggerClearPlaceholder"
                                                  Clicked="OnTriggerClearPlaceholderClicked"
                                                  AutomationId="TriggerClearPlaceholderButton"/>
                                   </Grid>

                                   <!-- Status Labels (events and command/parameter tracking) -->
                                   <Grid ColumnDefinitions="Auto,*"
                                         RowSpacing="4"
                                         ColumnSpacing="8"
                                         RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto">

                                          <!-- QueryChanged event log -->
                                          <Label Grid.Row="0"
                                                        Grid.Column="0"
                                                        Text="QueryChangedLog:"/>
                                          <Label Grid.Row="0"
                                                        Grid.Column="1"
                                                 x:Name="QueryChangedLog"
                                                 AutomationId="QueryChangedLog"
                                                 Text="{Binding QueryChangedLog}"/>

                                          <!-- Focus status (Focused/Unfocused events) -->
                                          <Label Grid.Row="1"
                                                        Grid.Column="0"
                                                        Text="FocusStatus:"/>
                                          <Label Grid.Row="1"
                                                        Grid.Column="1"
                                                 x:Name="FocusStatus"
                                                 AutomationId="FocusStatus"
                                                 Text="{Binding FocusStatus}"/>

                                          <!-- OnQueryConfirmed override fired -->
                                          <Label Grid.Row="2"
                                                        Grid.Column="0"
                                                        Text="CommandFired:"/>
                                          <Label Grid.Row="2"
                                                        Grid.Column="1"
                                                 x:Name="CommandFired"
                                                 AutomationId="CommandFired"
                                                 Text="{Binding CommandFired}"/>

                                          <!-- CommandParameter value -->
                                          <Label Grid.Row="3"
                                                        Grid.Column="0"
                                                        Text="CommandParameter:"/>
                                          <Label Grid.Row="3"
                                                        Grid.Column="1"
                                                 x:Name="CommandParameter"
                                                 AutomationId="CommandParameter"
                                                 Text="{Binding CommandParameter}"/>


                                          <!-- OnClearPlaceholderClicked override fired -->
                                          <Label Grid.Row="4"
                                                        Grid.Column="0"
                                                        Text="ClearPlaceholderCommandFired:"/>
                                          <Label Grid.Row="4"
                                                        Grid.Column="1"
                                                 x:Name="ClearPlaceholderCommandFired"
                                                 AutomationId="ClearPlaceholderCommandFired"
                                                 Text="{Binding ClearPlaceholderCommandFired}"/>

                                          <!-- ClearPlaceholderCommandParameter value -->
                                          <Label Grid.Row="5"
                                                        Grid.Column="0"
                                                        Text="ClearPlaceholderCommandParameter:"/>
                                          <Label Grid.Row="5"
                                                        Grid.Column="1"
                                                 x:Name="ClearPlaceholderCommandParameter"
                                                 AutomationId="ClearPlaceholderCommandParameter"
                                                 Text="{Binding ClearPlaceholderCommandParameter}"/>

                                          <!-- SelectedItem — last item tapped in suggestions dropdown -->
                                          <Label Grid.Row="6"
                                                        Grid.Column="0"
                                                        Text="SelectedItem:"/>
                                          <Label Grid.Row="6"
                                                        Grid.Column="1"
                                                 x:Name="SelectedItem"
                                                 AutomationId="SelectedItem"
                                                 Text="{Binding SelectedItem}"/>

                                   </Grid>

                            </VerticalStackLayout>
                     </ScrollView>
              </ContentPage>
       </ShellContent>
</Shell>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Maui.Controls.Sample"
             x:Class="Maui.Controls.Sample.RadioButtonOptionsPage"
             Title="RadioButtonFeature">
       <ContentPage.ToolbarItems>
              <ToolbarItem Text="Apply"
                           Clicked="ApplyButton_Clicked"
                           AutomationId="Apply"/>
       </ContentPage.ToolbarItems>

       <ScrollView>
              <Grid ColumnDefinitions="Auto, Auto"
                    RowDefinitions="Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto, Auto">

                     <!-- Content -->
                     <Label Grid.Row="0"
                            Grid.Column="0"
                            Text="Content:"
                            FontSize="14"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="0"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <Entry x:Name="ContentEntry"
                                   AutomationId="ContentEntry"
                                   TextChanged="OnContentChanged"
                                   HorizontalOptions="Start"
                                   WidthRequest="150"/>
                            <Button Text="Add View"
                                    BackgroundColor="Gray"
                                    TextColor="White"
                                    Clicked="ViewContentButton_Clicked"
                                    AutomationId="ViewContentButton"/>
                     </StackLayout>

                     <!-- 2x2 Numeric Options -->
                     <Grid Grid.Row="2"
                           Grid.Column="0"
                           Grid.ColumnSpan="2"
                           ColumnDefinitions="*, *"
                           RowDefinitions="Auto, Auto"
                           ColumnSpacing="20"
                           RowSpacing="10">
                            <VerticalStackLayout Grid.Row="0"
                                                 Grid.Column="0"
                                                 Spacing="4">
                                   <Label Text="Border Width:"
                                          FontSize="15"
                                          VerticalOptions="Center"/>
                                   <Entry x:Name="BorderWidthEntry"
                                          AutomationId="BorderWidthEntry"
                                          TextChanged="OnBorderWidthChanged"
                                          Keyboard="Numeric"
                                          HorizontalOptions="Start"
                                          WidthRequest="150"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="0"
                                                 Grid.Column="1"
                                                 Spacing="4">
                                   <Label Text="Character Spacing:"
                                          FontSize="15"
                                          VerticalOptions="Center"/>
                                   <Entry x:Name="CharacterSpacingEntry"
                                          AutomationId="CharacterSpacingEntry"
                                          TextChanged="OnCharacterSpacingChanged"
                                          Keyboard="Numeric"
                                          HorizontalOptions="Start"
                                          WidthRequest="150"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1"
                                                 Grid.Column="0"
                                                 Spacing="4">
                                   <Label Text="Corner Radius:"
                                          FontSize="15"
                                          VerticalOptions="Center"/>
                                   <Entry x:Name="CornerRadiusEntry"
                                          AutomationId="CornerRadiusEntry"
                                          TextChanged="OnCornerRadiusChanged"
                                          Keyboard="Numeric"
                                          HorizontalOptions="Start"
                                          WidthRequest="150"/>
                            </VerticalStackLayout>

                            <VerticalStackLayout Grid.Row="1"
                                                 Grid.Column="1"
                                                 Spacing="4">
                                   <Label Text="Font Size:"
                                          FontSize="15"
                                          VerticalOptions="Center"/>
                                   <Entry x:Name="FontSizeEntry"
                                          AutomationId="FontSizeEntry"
                                          TextChanged="OnFontSizeChanged"
                                          Keyboard="Numeric"
                                          HorizontalOptions="Start"
                                          WidthRequest="150"/>
                            </VerticalStackLayout>
                     </Grid>

                     <!-- IsChecked -->
                     <Label Grid.Row="3"
                            Grid.Column="0"
                            Text="Is Checked:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="3"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="IsCheckedTrueRadio"
                                         GroupName="IsChecked"
                                         Content="True"
                                         FontSize="14"
                                         CheckedChanged="OnIsCheckedChanged"/>
                            <RadioButton AutomationId="IsCheckedFalseRadio"
                                         GroupName="IsChecked"
                                         Content="False"
                                         IsChecked="True"
                                         FontSize="14"
                                         CheckedChanged="OnIsCheckedChanged"/>
                     </StackLayout>

                     <!-- GroupName -->
                     <Label Grid.Row="4"
                            Grid.Column="0"
                            Text="Group Name:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="4"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="GroupNameOneRadio"
                                         GroupName="GroupName"
                                         Content="Theme"
                                         IsChecked="True"
                                         FontSize="14"
                                         CheckedChanged="OnGroupNameChanged"/>
                            <RadioButton AutomationId="GroupNameTwoRadio"
                                         GroupName="GroupName"
                                         Content="Notification"
                                         FontSize="14"
                                         CheckedChanged="OnGroupNameChanged"/>
                     </StackLayout>

                     <!-- Value -->
                     <Label Grid.Row="1"
                            Grid.Column="0"
                            Text="Value:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <Entry Grid.Row="1"
                            Grid.Column="1"
                            x:Name="ValueEntry"
                            AutomationId="ValueEntry"
                            TextChanged="OnValueChanged"
                            HorizontalOptions="Start"
                            WidthRequest="150"/>

                     <!-- Border Color -->
                     <Label Grid.Row="5"
                            Grid.Column="0"
                            Text="Border Color:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="5"
                                  Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="5">
                            <Button Text="Default"
                                    BackgroundColor="Gray"
                                    TextColor="White"
                                    Clicked="BorderColorButton_Clicked"
                                    AutomationId="BorderColorDefaultButton"/>
                            <Button Text="Green"
                                    BackgroundColor="Green"
                                    TextColor="White"
                                    Clicked="BorderColorButton_Clicked"
                                    AutomationId="BorderColorGreenButton"/>
                            <Button Text="Purple"
                                    BackgroundColor="Purple"
                                    TextColor="White"
                                    Clicked="BorderColorButton_Clicked"
                                    AutomationId="BorderColorPurpleButton"/>
                     </StackLayout>

                     <!-- Flow Direction -->
                     <Label Grid.Row="6"
                            Grid.Column="0"
                            Text="Flow Direction:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="6"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="FlowDirectionLeftToRight"
                                         GroupName="FlowDirection"
                                         Content="Left to Right"
                                         FontSize="14"
                                         CheckedChanged="OnFlowDirectionChanged"/>
                            <RadioButton AutomationId="FlowDirectionRightToLeft"
                                         GroupName="FlowDirection"
                                         Content="Right to Left"
                                         FontSize="14"
                                         CheckedChanged="OnFlowDirectionChanged"/>
                     </StackLayout>

                     <!-- Font Attributes -->
                     <Label Grid.Row="7"
                            Grid.Column="0"
                            Text="Font Attributes:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="7"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="FontAttributesNone"
                                         GroupName="FontAttributes"
                                         Content="None"
                                         IsChecked="True"
                                         FontSize="14"
                                         CheckedChanged="OnFontAttributesChanged"/>
                            <RadioButton AutomationId="FontAttributesBold"
                                         GroupName="FontAttributes"
                                         Content="Bold"
                                         FontSize="14"
                                         CheckedChanged="OnFontAttributesChanged"/>
                            <RadioButton AutomationId="FontAttributesItalic"
                                         GroupName="FontAttributes"
                                         Content="Italic"
                                         FontSize="14"
                                         CheckedChanged="OnFontAttributesChanged"/>
                     </StackLayout>

                     <!-- Font Family -->
                     <Label Grid.Row="8"
                            Grid.Column="0"
                            Text="Font Family:"
                            FontSize="15"
                            VerticalOptions="Start"/>
                     <StackLayout Grid.Row="8"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="FontFamilyDokdo"
                                         GroupName="FontFamily"
                                         Content="Dokdo"
                                         FontSize="14"
                                         CheckedChanged="OnFontFamilyChanged"/>
                            <RadioButton AutomationId="FontFamilyMontserratBold"
                                         GroupName="FontFamily"
                                         Content="MontserratBold"
                                         FontSize="14"
                                         CheckedChanged="OnFontFamilyChanged"/>
                     </StackLayout>

                     <!-- Font Auto Scaling Enabled -->
                     <Label Grid.Row="9"
                            Grid.Column="0"
                            Text="Font Auto Scaling:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="9"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="FontAutoScalingEnabledTrueRadio"
                                         GroupName="FontAutoScaling"
                                         Content="True"
                                         IsChecked="True"
                                         FontSize="14"
                                         CheckedChanged="OnFontAutoScalingChanged"/>
                            <RadioButton AutomationId="FontAutoScalingEnabledFalseRadio"
                                         GroupName="FontAutoScaling"
                                         Content="False"
                                         FontSize="14"
                                         CheckedChanged="OnFontAutoScalingChanged"/>
                     </StackLayout>

                     <!-- Is Enabled -->
                     <Label Grid.Row="10"
                            Grid.Column="0"
                            Text="Is Enabled:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="10"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="IsEnabledTrueRadio"
                                         GroupName="IsEnabled"
                                         Content="True"
                                         IsChecked="True"
                                         FontSize="14"
                                         CheckedChanged="OnIsEnabledChanged"/>
                            <RadioButton AutomationId="IsEnabledFalseRadio"
                                         GroupName="IsEnabled"
                                         Content="False"
                                         FontSize="14"
                                         CheckedChanged="OnIsEnabledChanged"/>
                     </StackLayout>

                     <!-- Is Visible -->
                     <Label Grid.Row="11"
                            Grid.Column="0"
                            Text="Is Visible:"
                            FontSize="15"/>
                     <StackLayout Grid.Row="11"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="IsVisibleTrueRadio"
                                         GroupName="IsVisible"
                                         Content="True"
                                         IsChecked="True"
                                         FontSize="14"
                                         CheckedChanged="OnIsVisibleChanged"/>
                            <RadioButton AutomationId="IsVisibleFalseRadio"
                                         GroupName="IsVisible"
                                         Content="False"
                                         FontSize="14"
                                         CheckedChanged="OnIsVisibleChanged"/>
                     </StackLayout>

                     <!-- Text Color -->
                     <Label Grid.Row="12"
                            Grid.Column="0"
                            Text="Text Color:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="12"
                                  Grid.Column="1"
                                  Orientation="Horizontal"
                                  Spacing="5">
                            <Button Text="Default"
                                    BackgroundColor="Gray"
                                    TextColor="White"
                                    Clicked="TextColorButton_Clicked"
                                    AutomationId="TextColorDefaultButton"/>
                            <Button Text="Red"
                                    BackgroundColor="Red"
                                    TextColor="White"
                                    Clicked="TextColorButton_Clicked"
                                    AutomationId="TextColorRedButton"/>
                            <Button Text="Blue"
                                    BackgroundColor="Blue"
                                    TextColor="White"
                                    Clicked="TextColorButton_Clicked"
                                    AutomationId="TextColorBlueButton"/>
                     </StackLayout>

                     <!-- Text Transform -->
                     <Label Grid.Row="13"
                            Grid.Column="0"
                            Text="Text Transform:"
                            FontSize="15"
                            VerticalOptions="Center"/>
                     <StackLayout Grid.Row="13"
                                  Grid.Column="1"
                                  Orientation="Horizontal">
                            <RadioButton AutomationId="TextTransformNone"
                                         GroupName="TextTransform"
                                         Content="None"
                                         IsChecked="True"
                                         FontSize="14"
                                         CheckedChanged="OnTextTransformChanged"/>
                            <RadioButton AutomationId="TextTransformUpper"
                                         GroupName="TextTransform"
                                         Content="Upper"
                                         FontSize="14"
                                         CheckedChanged="OnTextTransformChanged"/>
                            <RadioButton AutomationId="TextTransformLower"
                                         GroupName="TextTransform"
                                         Content="Lower"
                                         FontSize="14"
                                         CheckedChanged="OnTextTransformChanged"/>
                     </StackLayout>

                     <!-- Selected Value -->
                     <Label Grid.Row="14"
                            Grid.Column="0"
                            Text="Selected Value:"
                            FontSize="16"
                            Margin="0,0,10,10"/>
                     <StackLayout Orientation="Horizontal"
                                  Grid.Row="14"
                                  Grid.Column="1">
                            <RadioButton AutomationId="SelectedValueRadioButtonOne"
                                         Content="One"
                                         CheckedChanged="OnSelectedRadioButton_CheckedChanged"/>
                            <RadioButton AutomationId="SelectedValueRadioButtonTwo"
                                         Content="Two"
                                         CheckedChanged="OnSelectedRadioButton_CheckedChanged"/>
                            <RadioButton AutomationId="SelectedValueRadioButtonThree"
                                         Content="Three"
                                         CheckedChanged="OnSelectedRadioButton_CheckedChanged"/>
                     </StackLayout>
              </Grid>
       </ScrollView>
</ContentPage>

<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Maui.Controls.Sample.SimpleTemplatePerformancePage"
             Title="Simple Template Performance">

    <Grid RowDefinitions="Auto,*,Auto">
        <VerticalStackLayout Grid.Row="0"
                Padding="10"
                BackgroundColor="LightGray">
            <Label x:Name="StatusLabel"
                    Text="Ready"
                    FontSize="16"
                    FontAttributes="Bold"
                    AutomationId="StatusLabel"/>
            <Label x:Name="ItemCountLabel"
                    Text="Items: 0"
                    FontSize="12"
                    AutomationId="ItemCountLabel"/>
            <Label x:Name="TimingLabel"
                    Text="Load Time: --"
                    FontSize="12"
                    AutomationId="TimingLabel"/>
        </VerticalStackLayout>

        <CollectionView x:Name="CV"
                Grid.Row="1"
                AutomationId="PerformanceCollectionView">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Stroke="LightGray"
                            StrokeThickness="1"
                            Padding="10"
                            Margin="2">
                        <Label Text="{Binding}"
                                FontSize="14"/>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid Grid.Row="2"
                Padding="10"
                ColumnDefinitions="*,*,*,*"
                ColumnSpacing="8">
            <Button Grid.Column="0"
                    Text="Load 100"
                    Clicked="OnLoad100"
                    AutomationId="Load100Button"/>
            <Button Grid.Column="1"
                    Text="Load 1000"
                    Clicked="OnLoad1000"
                    AutomationId="Load1000Button"/>
            <Button Grid.Column="2"
                    Text="Clear"
                    Clicked="OnClear"
                    AutomationId="ClearButton"/>
            <Button Grid.Column="3"
                    Text="Scroll End"
                    Clicked="OnScrollEnd"
                    AutomationId="ScrollEndButton"/>
        </Grid>
    </Grid>
</ContentPage>

<ContentPage x:Class="Maui.Controls.Sample.MainPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:Maui.Controls.Sample"
             Title="Null Item CollectionView2 – Drag / Selection">

    <ContentPage.Resources>
        <DataTemplate x:Key="ItemTemplate">
            <Grid Padding="12,8" BackgroundColor="#F0F0F0" Margin="4,2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- Null items show a "(null)" placeholder; non-null items show their value -->
                <Label Grid.Column="0"
                       Text="{Binding ., StringFormat='Item: {0}', TargetNullValue='(null item)'}"
                       VerticalOptions="Center"
                       FontSize="16"/>
                <Label Grid.Column="1"
                       Text="☰"
                       FontSize="20"
                       VerticalOptions="Center"
                       Margin="8,0,0,0"
                       TextColor="Gray"/>
            </Grid>
        </DataTemplate>
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,Auto,*,Auto" Padding="16">

        <!-- Title / description -->
        <Label Grid.Row="0"
               Text="CollectionView2 – Null Item Bugs"
               FontSize="20" FontAttributes="Bold"
               Margin="0,0,0,4"/>

        <!-- Bug status panel -->
        <VerticalStackLayout Grid.Row="1" Spacing="4" Margin="0,0,0,12">
            <Label Text="• Drag a (null item) → should reorder without cancelling"
                   FontSize="13" TextColor="#444"/>
            <Label Text="• Tap a (null item) → should NOT appear pre-selected (false selection)"
                   FontSize="13" TextColor="#444"/>
            <Label Text="• Replace a grouped null item → grouped list should stay in sync"
                   FontSize="13" TextColor="#444"/>
            <Label x:Name="StatusLabel"
                   Text="Status: ready"
                   FontSize="13"
                   TextColor="DarkGreen"
                   Margin="0,4,0,0"/>
        </VerticalStackLayout>

        <!-- CollectionView2 with null items and CanReorderItems -->
        <CollectionView Grid.Row="2"
                        x:Name="TheCollectionView"
                        ItemsLayout="VerticalList"
                        SelectionMode="Single"
                        CanReorderItems="True"
                        ItemTemplate="{StaticResource ItemTemplate}"
                        SelectionChanged="OnSelectionChanged"
                        ReorderCompleted="OnReorderCompleted"
                        BackgroundColor="#FAFAFA"/>

        <!-- Action buttons -->
        <Grid Grid.Row="3" ColumnDefinitions="*,*,*" ColumnSpacing="8" Margin="0,12,0,0">
            <Button Grid.Column="0"
                    Text="Insert null"
                    Clicked="OnInsertNull"
                    BackgroundColor="#2196F3"
                    TextColor="White"/>
            <Button Grid.Column="1"
                    Text="Replace→null"
                    Clicked="OnReplaceWithNull"
                    BackgroundColor="#FF9800"
                    TextColor="White"/>
            <Button Grid.Column="2"
                    Text="Reset list"
                    Clicked="OnReset"
                    BackgroundColor="#9E9E9E"
                    TextColor="White"/>
        </Grid>

    </Grid>
</ContentPage>

<Project>
  <PropertyGroup>
    <EnableDefaultMauiItems Condition=" '$(EnableDefaultMauiItems)' == '' ">$(EnableDefaultItems)</EnableDefaultMauiItems>
    <EnableDefaultMauiXamlItems Condition=" '$(EnableDefaultMauiXamlItems)' == '' ">$(EnableDefaultMauiItems)</EnableDefaultMauiXamlItems>
    <EnableDefaultMauiCssItems  Condition=" '$(EnableDefaultMauiCssItems)' == '' ">$(EnableDefaultMauiItems)</EnableDefaultMauiCssItems>

    <EnableDefaultMauiItems Condition=" '$(EnableDefaultItems)' != 'true' ">false</EnableDefaultMauiItems>
    <EnableDefaultMauiXamlItems Condition=" '$(EnableDefaultMauiItems)' != 'true' ">false</EnableDefaultMauiXamlItems>
    <EnableDefaultMauiCssItems  Condition=" '$(EnableDefaultMauiItems)' != 'true' ">false</EnableDefaultMauiCssItems>
  </PropertyGroup>
  <Import Project="../targets/Microsoft.Maui.Controls.targets" />
  <Import Project="WinUI.targets" Condition=" '$(TargetPlatformIdentifier)' == 'windows' " />
  <ItemGroup Condition=" '$(DisableMauiAnalyzers)' != 'true' ">
    <Analyzer Include="$(MSBuildThisFileDirectory)../targets/Microsoft.Maui.Controls.dll" />
    <Analyzer Include="$(MSBuildThisFileDirectory)../targets/Microsoft.Maui.Controls.Xaml.dll" />
    <Analyzer Include="$(MSBuildThisFileDirectory)../targets/Microsoft.Maui.Controls.SourceGen.dll" />
  </ItemGroup>
</Project>
<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Maui.Controls.Sample.ViewModels"
    xmlns:views="clr-namespace:Maui.Controls.Sample.Views.Itinerary"
    x:Class="Maui.Controls.Sample.Pages.TripPlanningPage"
    x:DataType="viewModels:TripPlanningViewModel"
    Title="{Binding Landmark.Name}">

    <!-- Matches Swift TripPlanningView - simple switch based on availability -->
    
    <Grid>
        <!-- If AI is available, show LandmarkTripView -->
        <views:LandmarkTripView IsVisible="{Binding ShowLandmarkTripView}" />
        
        <!-- If AI is unavailable or error, show MessageView -->
        <views:MessageView IsVisible="{Binding ShowMessageView}" />
    </Grid>

</ContentPage>

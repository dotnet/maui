<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:viewModels="clr-namespace:Maui.Controls.Sample.ViewModels"
    x:Class="Maui.Controls.Sample.Pages.MainPage"
    x:DataType="viewModels:ChatViewModel"
    Title="AI Chat">

    <Grid
        RowDefinitions="*,Auto"
        Padding="10">

        <!-- Chat Messages -->
        <CollectionView
            x:Name="MessagesCollectionView"
            ItemsSource="{Binding Messages}"
            SelectionMode="None">
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="viewModels:MessageViewModel">
                    <StackLayout Padding="10,5">
                        <Border
                            BackgroundColor="{Binding BackgroundColor}"
                            Padding="10"
                            StrokeShape="RoundRectangle 10"
                            HorizontalOptions="{Binding HorizontalAlignment}">
                            <Label
                                Text="{Binding Text}"
                                TextColor="{Binding TextColor}"
                                LineBreakMode="WordWrap"/>
                        </Border>
                    </StackLayout>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Input Area -->
        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,Auto"
            ColumnSpacing="10"
            Padding="0,10,0,0">
            <Entry
                x:Name="MessageEntry"
                Placeholder="Type your message..."
                ReturnCommand="{Binding SendMessageCommand}"
                ReturnType="Send"/>
            <Button
                Grid.Column="1"
                Text="Send"
                Command="{Binding SendMessageCommand}"
                WidthRequest="80"/>
        </Grid>

    </Grid>

</ContentPage>

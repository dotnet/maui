<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>$(_MauiDotNetTfm)</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>Server</RootNamespace>
    <UserSecretsId>maui-essentials-auth-server</UserSecretsId>
    <BlazorDisableThrowNavigationException>true</BlazorDisableThrowNavigationException>
    <!-- This is a developer-facing reference server for the .NET MAUI Essentials auth samples. It
         hosts BOTH the passkeys relying party (ASP.NET Core Identity / WebAuthn) AND the OAuth
         "pass-through" backend for the WebAuthenticator sample, so testing is "launch one web app,
         run the MAUI app". Build and run it locally (see README.md). -->
    <IsPackable>false</IsPackable>
    <!-- EF Core packages are pinned to the same servicing band as the rest of the repo so they
         restore from the repo's own feeds (no nuget.org needed for this project). -->
    <_PasskeysEfCoreVersion>11.0.0-preview.6.26325.125</_PasskeysEfCoreVersion>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Diagnostics.EntityFrameworkCore" Version="$(_PasskeysEfCoreVersion)" />
    <PackageReference Include="Microsoft.AspNetCore.Identity.EntityFrameworkCore" Version="$(_PasskeysEfCoreVersion)" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Sqlite" Version="$(_PasskeysEfCoreVersion)" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="$(_PasskeysEfCoreVersion)" PrivateAssets="all" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Tools" Version="$(_PasskeysEfCoreVersion)" />
  </ItemGroup>

  <!-- OAuth "pass-through" providers for the WebAuthenticator sample. Facebook/Google/Microsoft use
       repo-managed versions; Apple comes from the community package. -->
  <ItemGroup>
    <PackageReference Include="AspNet.Security.OAuth.Apple" Version="9.2.0" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Facebook" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Google" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.MicrosoftAccount" />
  </ItemGroup>

</Project>

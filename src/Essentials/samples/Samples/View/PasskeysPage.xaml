<views:BasePage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:views="clr-namespace:Samples.View"
                xmlns:viewmodels="clr-namespace:Samples.ViewModel"
                x:Class="Samples.View.PasskeysPage"
                Title="Passkeys">
    <views:BasePage.BindingContext>
        <viewmodels:PasskeysViewModel />
    </views:BasePage.BindingContext>

    <ScrollView>
        <StackLayout Padding="12" Spacing="8">

            <Label Text="Register and sign in with a passkey (WebAuthn/FIDO2) against the reference ASP.NET Core Identity relying-party server (Samples.WebServer)."
                   FontAttributes="Bold" />

            <Label Text="{Binding SupportedText}" FontAttributes="Italic" />

            <Label Text="Server base URL" FontAttributes="Bold" Margin="0,8,0,0" />
            <Entry Text="{Binding ServerBaseUrl}" Placeholder="https://your-tunnel.devtunnels.ms" Keyboard="Url" />
            <Label Text="On a real device the server must be reachable at the same domain as the RP ID (use a dev tunnel). See the server README."
                   FontSize="12" TextColor="Gray" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="① Account (username + password)" FontAttributes="Bold" />
            <Label Text="The real bootstrap: sign in against your own ASP.NET Core Identity server. No browser — just a native form post that sets the session cookie."
                   FontSize="12" TextColor="Gray" />
            <Entry Text="{Binding Username}" Placeholder="alice@example.com" Keyboard="Email" />
            <Entry Text="{Binding Password}" Placeholder="Password" IsPassword="True" />
            <Button Text="Sign up (new account)" Command="{Binding SignUpCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Text="Sign in with password" Command="{Binding SignInPasswordCommand}" IsEnabled="{Binding IsNotBusy}" />
            <Button Text="Sign out" Command="{Binding SignOutCommand}" IsEnabled="{Binding IsNotBusy}" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="② Enroll a passkey (after signing in)" FontAttributes="Bold" />
            <Label Text="Offered once you're authenticated — the server binds the new passkey to the logged-in user."
                   FontSize="12" TextColor="Gray" />
            <Button Text="Create a passkey" Command="{Binding RegisterCommand}" IsEnabled="{Binding IsNotBusy}" />

            <BoxView HeightRequest="1" Color="LightGray" Margin="0,8" />

            <Label Text="③ Fast sign-in with a passkey" FontAttributes="Bold" />
            <Label Text="Username-less: the username/password above are ignored here. The OS account picker lists your passkeys and you just pick one — the passkey carries the identity. No password, no browser."
                   FontSize="12" TextColor="Gray" />
            <Button Text="Sign in with a passkey" Command="{Binding LoginCommand}" IsEnabled="{Binding IsNotBusy}" />

            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}" />

            <Label Text="Log" FontAttributes="Bold" Margin="0,8,0,0" />
            <Label Text="{Binding Status}" FontFamily="Monospace" FontSize="12" />

        </StackLayout>
    </ScrollView>

</views:BasePage>

<Project Sdk="Microsoft.NET.Sdk">
  <!-- Import Component Governance manifest generation targets -->
  <Import Project="$(MSBuildThisFileDirectory)../../../eng/CgManifest.targets" />
  
  <UsingTask TaskName="ReplaceFileText" TaskFactory="RoslynCodeTaskFactory" AssemblyFile="$(MSBuildToolsPath)\Microsoft.Build.Tasks.Core.dll">
    <ParameterGroup>
      <InputFilename ParameterType="System.String" Required="true" />
      <OutputFilename ParameterType="System.String" Required="true" />
      <MatchExpression ParameterType="System.String[]" Required="true" />
      <ReplacementText ParameterType="System.String[]" Required="true" />
    </ParameterGroup>
    <Task>
      <Using Namespace="System" />
      <Using Namespace="System.IO" />
      <Using Namespace="System.Text.RegularExpressions" />
      <Code Type="Fragment" Language="cs">
        <![CDATA[
            if (MatchExpression.Length != ReplacementText.Length) throw new Exception("The number of MatchExpression items must match the number of ReplacementText items.");

            for (int i = 0; i < MatchExpression.Length; i++)
            {
                File.WriteAllText(
                    OutputFilename,
                    Regex.Replace(File.ReadAllText(InputFilename), MatchExpression[i], ReplacementText[i])
                    );
                //Console.WriteLine($"Processing file '{InputFilename}' --> '{OutputFilename}', replacing match '{MatchExpression[i]}' with text '{ReplacementText[i]}'.");
            }
          ]]>
      </Code>
    </Task>
  </UsingTask>

  <PropertyGroup>
    <TargetFramework>$(_MauiDotNetTfm)</TargetFramework>
    <SuppressDependenciesWhenPacking>true</SuppressDependenciesWhenPacking>
    <IncludeContentInPack>true</IncludeContentInPack>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <LocalizeTemplates>true</LocalizeTemplates>
    <IncludeSymbols>false</IncludeSymbols>
    <ContentTargetFolders>content</ContentTargetFolders>
    <!-- This project has no .NET assemblies, so disable the warning for that -->
    <NoWarn>$(NoWarn);NU5128</NoWarn>
  </PropertyGroup>

  <PropertyGroup>
    <!-- NuGet package information -->
    <IsPackable>true</IsPackable>
    <PackageId>Microsoft.Maui.Templates.net$(_MauiDotNetVersionMajor)</PackageId>
    <PackageType>Template</PackageType>
    <Title>.NET MAUI Templates</Title>
    <Description>.NET Multi-platform App UI (.NET MAUI) project and item templates.</Description>
  </PropertyGroup>

  <ItemGroup>
    <TemplateJsonInput Include="templates\*\.template.config\**\*.json">
      <PackageDestination>$([System.String]::Concat(%(RelativeDir), '%(Filename)%(Extension)'))</PackageDestination>
      <IntermediateLocation>$(IntermediateOutputPath)$([System.String]::Concat(%(RelativeDir), '%(Filename)%(Extension)'))</IntermediateLocation>
    </TemplateJsonInput>
    <Content Include="templates\**\*" Exclude="templates\**\bin\**;templates\**\obj\**;@(TemplateJsonInput)" />
    <!-- Only include cgmanifest.json when GenerateCgManifest is true (for CI builds) -->
    <Content Include="cgmanifest.json" Pack="true" PackagePath="content" Condition="'$(GenerateCgManifest)' == 'true'" />
    <Compile Remove="**\*" />
  </ItemGroup>

  <PropertyGroup>
    <BeforePack>TestDotNetPackageVersionSelection;_UpdateTemplateVersions</BeforePack>
  </PropertyGroup>

  <Target Name="_GetTemplatePackageVersions">
    <ItemGroup>
      <_TemplatePackageVersion Include="MS_EXT_LOG_DEBUG_VERSION_VALUE">
        <CurrentVersion>$(MicrosoftExtensionsLoggingDebugVersion)</CurrentVersion>
        <ReplacementVersion>$(MicrosoftExtensionsLoggingDebugVersion)</ReplacementVersion>
        <ReplacementVersion Condition="$(MicrosoftExtensionsLoggingDebugVersion.Contains('-'))">*</ReplacementVersion>
      </_TemplatePackageVersion>
      <_TemplatePackageVersion Include="MS_COMPONENTS_WEB_VERSION_VALUE">
        <CurrentVersion>$(MicrosoftAspNetCoreComponentsWebPackageVersion)</CurrentVersion>
        <ReplacementVersion>$(MicrosoftAspNetCoreComponentsWebPackageVersion)</ReplacementVersion>
        <ReplacementVersion Condition="$(MicrosoftAspNetCoreComponentsWebPackageVersion.Contains('-'))">*</ReplacementVersion>
      </_TemplatePackageVersion>
      <_TemplatePackageVersion Include="MS_COMPONENTS_WEBASSEMBLY_VERSION_VALUE">
        <CurrentVersion>$(MicrosoftAspNetCoreComponentsWebAssemblyPackageVersion)</CurrentVersion>
        <ReplacementVersion>$(MicrosoftAspNetCoreComponentsWebAssemblyPackageVersion)</ReplacementVersion>
        <ReplacementVersion Condition="$(MicrosoftAspNetCoreComponentsWebAssemblyPackageVersion.Contains('-'))">*</ReplacementVersion>
      </_TemplatePackageVersion>
      <_TemplatePackageVersion Include="MS_COMPONENTS_WEBASSEMBLY_SERVER_VERSION_VALUE">
        <CurrentVersion>$(MicrosoftAspNetCoreComponentsWebAssemblyServerPackageVersion)</CurrentVersion>
        <ReplacementVersion>$(MicrosoftAspNetCoreComponentsWebAssemblyServerPackageVersion)</ReplacementVersion>
        <ReplacementVersion Condition="$(MicrosoftAspNetCoreComponentsWebAssemblyServerPackageVersion.Contains('-'))">*</ReplacementVersion>
      </_TemplatePackageVersion>
    </ItemGroup>
  </Target>

  <!-- Version-only dependency updates must refresh packed defaults even when template files are unchanged. -->
  <Target Name="_UpdateTemplateVersions" DependsOnTargets="SetVersions;LocalizeTemplatesAfterBuild;_GetTemplatePackageVersions">

     <!-- Copy files to their output name -->
    <Copy
        SourceFiles="%(TemplateJsonInput.Fullpath)"
        DestinationFiles="%(TemplateJsonInput.IntermediateLocation)" />

     <!-- Copy the templatestrings.en.json to templatestrings.json -->
    <Copy
        SourceFiles="%(TemplateJsonInput.Fullpath)"
        DestinationFiles="%(TemplateJsonInput.RelativeDir)templatestrings.json"
        Condition="'%(TemplateJsonInput.Filename)%(TemplateJsonInput.Extension)' == 'templatestrings.en.json'" />

    <!-- Replace .NET TFM versions -->
    <ReplaceFileText
        InputFilename="%(TemplateJsonInput.IntermediateLocation)"
        OutputFilename="%(TemplateJsonInput.IntermediateLocation)"
        MatchExpression="DOTNET_TFM_VALUE;DOTNET_TFM_VERSION_VALUE;DOTNET_TFM_VERSION_MAJOR_VALUE"
        ReplacementText="$(_MauiDotNetTfm);$(_MauiDotNetVersion);$(_MauiDotNetVersionMajor)000" />
    <ReplaceFileText
        InputFilename="%(TemplateJsonInput.IntermediateLocation)"
        OutputFilename="%(TemplateJsonInput.IntermediateLocation)"
        MatchExpression="@(_TemplatePackageVersion)"
        ReplacementText="@(_TemplatePackageVersion->'%(ReplacementVersion)')" />

    <ItemGroup>
      <FileWrites Include="%(TemplateJsonInput.IntermediateLocation)" />
      <Content Include="%(TemplateJsonInput.IntermediateLocation)" PackagePath="$(ContentTargetFolders)\%(TemplateJsonInput.PackageDestination)" Pack="true" />
    </ItemGroup>

  </Target>

  <ItemGroup Condition="'$(TestDotNetPackageVersionSelection)' == 'true'">
    <PackageReference Include="Microsoft.Extensions.Configuration" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Json" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.DependencyInjection.Abstractions" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.FileProviders.Abstractions" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Hosting.Abstractions" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Http" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Logging" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Logging.Console" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Logging.Debug" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Extensions.Primitives" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Authorization" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Facebook" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.Google" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Authentication.MicrosoftAccount" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Components.Analyzers" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Components.Forms" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Components" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Components.Web" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly.Server" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Components.WebView" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.AspNetCore.Metadata" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.JSInterop" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="System.Text.Json" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="System.Text.Encodings.Web" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="Microsoft.Bcl.AsyncInterfaces" TestDotNetPackageVersionSelection="true" />
    <PackageReference Include="System.CodeDom" TestDotNetPackageVersionSelection="true" />
  </ItemGroup>

  <Target Name="_GetDotNetPackageVersionSelection" DependsOnTargets="_GetTemplatePackageVersions">
    <Error
        Condition="'%(PackageReference.TestDotNetPackageVersionSelection)' == 'true' and '%(PackageReference.Version)' != '$(ExpectedDotNetPackageVersion)'"
        Text="Expected %(PackageReference.Identity) to use $(ExpectedDotNetPackageVersion), but it uses %(PackageReference.Version)." />
    <Error
        Condition="'%(_TemplatePackageVersion.ReplacementVersion)' != '$(ExpectedTemplatePackageVersion)'"
        Text="Expected template placeholder %(_TemplatePackageVersion.Identity) to use $(ExpectedTemplatePackageVersion), but it uses %(_TemplatePackageVersion.ReplacementVersion)." />
  </Target>

  <Target Name="TestDotNetPackageVersionSelection">
    <ItemGroup>
      <_DotNetNVersionProperty Include="MicrosoftNETCoreAppRefPackageVersion" />
      <_DotNetNVersionProperty Include="SystemTextJsonPackageVersion" />
      <_DotNetNVersionProperty Include="SystemTextEncodingsWebPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftBclAsyncInterfacesPackageVersion" />
      <_DotNetNVersionProperty Include="SystemCodeDomPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsConfigurationVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsConfigurationAbstractionsVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsConfigurationJsonVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsDependencyInjectionVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsDependencyInjectionAbstractionsVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsFileProvidersAbstractionsVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsHostingAbstractionsVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsHttpVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsLoggingAbstractionsVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsLoggingVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsLoggingConsoleVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsLoggingDebugVersion" />
      <_DotNetNVersionProperty Include="MicrosoftExtensionsPrimitivesVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreAuthorizationPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreAuthenticationFacebookPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreAuthenticationGooglePackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreAuthenticationMicrosoftAccountPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreComponentsAnalyzersPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreComponentsFormsPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreComponentsPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreComponentsWebPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreComponentsWebAssemblyPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreComponentsWebAssemblyServerPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreComponentsWebViewPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftAspNetCoreMetadataPackageVersion" />
      <_DotNetNVersionProperty Include="MicrosoftJSInteropPackageVersion" />

      <_DotNetN1VersionProperty Include="MicrosoftNETCoreAppRefN1PackageVersion" />
      <_DotNetN1VersionProperty Include="SystemTextJsonN1PackageVersion" />
      <_DotNetN1VersionProperty Include="SystemTextEncodingsWebN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftBclAsyncInterfacesN1PackageVersion" />
      <_DotNetN1VersionProperty Include="SystemCodeDomN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsConfigurationN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsConfigurationAbstractionsN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsConfigurationJsonN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsDependencyInjectionN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsDependencyInjectionAbstractionsN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsFileProvidersAbstractionsN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsHostingAbstractionsN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsHttpN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsLoggingAbstractionsN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsLoggingN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsLoggingConsoleN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsLoggingDebugN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftExtensionsPrimitivesN1Version" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreAuthorizationN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreAuthenticationFacebookN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreAuthenticationGoogleN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreAuthenticationMicrosoftAccountN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreComponentsAnalyzersN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreComponentsFormsN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreComponentsN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreComponentsWebN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreComponentsWebAssemblyN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreComponentsWebAssemblyServerN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreComponentsWebViewN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftAspNetCoreMetadataN1PackageVersion" />
      <_DotNetN1VersionProperty Include="MicrosoftJSInteropN1PackageVersion" />
    </ItemGroup>
    <PropertyGroup>
      <_PreviewNProperties>@(_DotNetNVersionProperty->'%(Identity)=11.0.0-preview.7.26364.110', ';')</_PreviewNProperties>
      <_StableNProperties>@(_DotNetNVersionProperty->'%(Identity)=11.0.0', ';')</_StableNProperties>
      <_StableN1Properties>@(_DotNetN1VersionProperty->'%(Identity)=10.0.0', ';')</_StableN1Properties>
    </PropertyGroup>

    <MSBuild
        Projects="$(MSBuildProjectFullPath)"
        Targets="_GetDotNetPackageVersionSelection"
        Properties="TestDotNetPackageVersionSelection=true;UseN1PackageVersions=true;$(_PreviewNProperties);ExpectedDotNetPackageVersion=$(MicrosoftExtensionsConfigurationN1Version);ExpectedTemplatePackageVersion=*" />
    <MSBuild
        Projects="$(MSBuildProjectFullPath)"
        Targets="_GetDotNetPackageVersionSelection"
        Properties="TestDotNetPackageVersionSelection=true;UseN1PackageVersions=false;$(_PreviewNProperties);ExpectedDotNetPackageVersion=11.0.0-preview.7.26364.110;ExpectedTemplatePackageVersion=*" />
    <MSBuild
        Projects="$(MSBuildProjectFullPath)"
        Targets="_GetDotNetPackageVersionSelection"
        Properties="TestDotNetPackageVersionSelection=true;UseN1PackageVersions=true;$(_PreviewNProperties);$(_StableN1Properties);ExpectedDotNetPackageVersion=10.0.0;ExpectedTemplatePackageVersion=*" />
    <MSBuild
        Projects="$(MSBuildProjectFullPath)"
        Targets="_GetDotNetPackageVersionSelection"
        Properties="TestDotNetPackageVersionSelection=true;UseN1PackageVersions=true;$(_StableNProperties);ExpectedDotNetPackageVersion=11.0.0;ExpectedTemplatePackageVersion=11.0.0" />
  </Target>

  <Target Name="_CopyToTemplatePacks" AfterTargets="Pack">
    <ItemGroup>
      <_PackagesToCopy Include="$(PackageOutputPath)/$(PackageId).*.nupkg" />
    </ItemGroup>
    <Copy
        SourceFiles="@(_PackagesToCopy)"
        DestinationFolder="$(DotNetTemplatePacksDirectory)"
        SkipUnchangedFiles="true"
    />
  </Target>

  <!-- CgManifest generation configuration -->
  <PropertyGroup>
    <!-- Always generate the file, but only include in package when explicitly requested -->
    <UpdateCgManifestBeforeBuild>true</UpdateCgManifestBeforeBuild>
    <!-- Controls whether to include cgmanifest.json in the package (default: false) -->
    <GenerateCgManifest Condition="'$(GenerateCgManifest)' == ''">false</GenerateCgManifest>
  </PropertyGroup>
  
  <ItemGroup Condition=" '$(OS)' == 'Windows_NT' ">
    <PackageReference Include="Microsoft.TemplateEngine.Tasks" Version="$(MicrosoftTemplateEngineTasksVersion)" PrivateAssets="all" IsImplicitlyDefined="true" />
  </ItemGroup>

  <!-- this target will get replaced by the nuget -->
  <Target Name="LocalizeTemplatesAfterBuild" />

</Project>

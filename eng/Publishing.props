<Project>
  <PropertyGroup>
    <PublishingVersion>3</PublishingVersion>
    <ProducesDotNetReleaseShippingAssets>true</ProducesDotNetReleaseShippingAssets>
  </PropertyGroup>

  <ItemGroup>
    <_InstallersToPublish Include="$(ArtifactsShippingPackagesDir)\**\*.zip" />
  </ItemGroup>

  <PropertyGroup>
    <_PackageVersion>@(_PackageIdentity->'%(Version)')</_PackageVersion>
  </PropertyGroup>

  <PropertyGroup>
    <_UploadPathRoot>maui</_UploadPathRoot>
  </PropertyGroup>

  <ItemGroup>
    <Artifact Include="@(_InstallersToPublish)" Kind="Blob" RelativeBlobPath="$(_UploadPathRoot)/$(AssetVersion)/%(Filename)%(Extension)">
      <IsShipping>true</IsShipping>
      <IsShipping Condition="$([System.String]::Copy('%(RecursiveDir)').StartsWith('NonShipping'))">false</IsShipping>
      <PublishFlatContainer>true</PublishFlatContainer>
    </Artifact>
  </ItemGroup>
</Project>
<Project>
  <PropertyGroup>
    <UseN1PackageVersions Condition="'$(UseN1PackageVersions)' == '' and '$(MauiTestProject)' == 'true'">false</UseN1PackageVersions>
    <UseN1PackageVersions Condition="'$(UseN1PackageVersions)' == ''">true</UseN1PackageVersions>
    <MicrosoftDotNetN1PackageVersion>11.0.0-preview.6.26359.118</MicrosoftDotNetN1PackageVersion>
  </PropertyGroup>

  <ItemGroup Condition="'$(UseN1PackageVersions)' == 'true' and $(MicrosoftExtensionsConfigurationVersion.Contains('-'))">
    <PackageReference Update="Microsoft.Extensions.Configuration" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Configuration.Abstractions" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Configuration.Json" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.DependencyInjection" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.DependencyInjection.Abstractions" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.FileProviders.Abstractions" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Hosting.Abstractions" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Http" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Logging.Abstractions" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Logging" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Logging.Console" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Logging.Debug" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Extensions.Primitives" Version="$(MicrosoftDotNetN1PackageVersion)" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseN1PackageVersions)' == 'true' and $(MicrosoftAspNetCoreAuthorizationPackageVersion.Contains('-'))">
    <PackageReference Update="Microsoft.AspNetCore.Authorization" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Authentication.Google" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Authentication.Facebook" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Authentication.MicrosoftAccount" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Components.Analyzers" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Components.Forms" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Components" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Components.WebView" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Components.Web" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Components.WebAssembly" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Components.WebAssembly.Server" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.AspNetCore.Metadata" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.JSInterop" Version="$(MicrosoftDotNetN1PackageVersion)" />
  </ItemGroup>

  <ItemGroup Condition="'$(UseN1PackageVersions)' == 'true' and $(MicrosoftNETCoreAppRefPackageVersion.Contains('-'))">
    <PackageReference Update="System.Text.Json" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="System.Text.Encodings.Web" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="System.CodeDom" Version="$(MicrosoftDotNetN1PackageVersion)" />
    <PackageReference Update="Microsoft.Bcl.AsyncInterfaces" Version="$(MicrosoftDotNetN1PackageVersion)" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference
        Update="HarfBuzzSharp"
        Version="$(_HarfBuzzSharpVersion)"
    />
    <PackageReference
        Update="HarfBuzzSharp.NativeAssets.Linux"
        Version="$(_HarfBuzzSharpVersion)"
    />
    <PackageReference
        Update="HarfBuzzSharp.NativeAssets.macOS"
        Version="$(_HarfBuzzSharpVersion)"
    />
    <PackageReference
        Update="HarfBuzzSharp.NativeAssets.Win32"
        Version="$(_HarfBuzzSharpVersion)"
    />
    <PackageReference
        Update="SkiaSharp.HarfBuzz"
        Version="$(_SkiaSharpVersion)"
    />
    <PackageReference
        Update="SkiaSharp.Extended"
        Version="$(_SkiaSharpExtendedVersion)"
    />

        Version="$(MicrosoftAspNetCoreAuthenticationGooglePackageVersion)"
        Condition="'$(UseN1PackageVersions)' != 'true' or !$(MicrosoftAspNetCoreAuthorizationPackageVersion.Contains('-'))"
    />
    <PackageReference

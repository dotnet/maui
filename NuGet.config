<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <!-- Define the package sources: all mirrors or internal feeds. -->
  <!-- `clear` ensures no additional sources are inherited from another config file. -->
  <packageSources>
    <clear />
    <!--
      Local development overrides: uncomment these to use locally-built packages
      from feature branches. These take precedence over CI feeds when the version matches.
      Comment these out and use the CI feed versions once features merge to main.
    -->
    <!-- <add key="android-tools-local" value="/path/to/android-tools/nupkgs" /> -->
    <!-- <add key="macios-devtools-local" value="/path/to/macios-devtools/nupkgs" /> -->
    <!--  Begin: Package sources from dotnet-android-tools -->
    <add key="darc-pub-dotnet-android-tools" value="https://pkgs.dev.azure.com/xamarin/public/_packaging/Xamarin.Android/nuget/v3/index.json" />
    <!--  End: Package sources from dotnet-android-tools -->
    <!--  Begin: Package sources from dotnet-macios-devtools (local until CI feed is set up) -->
    <add key="macios-devtools-local" value="LOCAL_MACIOS_DEVTOOLS_PLACEHOLDER" />
    <!--  End: Package sources from dotnet-macios-devtools -->
    <!--  Begin: Package sources from dotnet-dotnet -->
    <add key="darc-pub-dotnet-dotnet-e17b0d0" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/darc-pub-dotnet-dotnet-e17b0d08/nuget/v3/index.json" />
    <!--  End: Package sources from dotnet-dotnet -->
    <add key="local" value="LOCAL_PLACEHOLDER" />
    <add key="nuget-only" value="NUGET_ONLY_PLACEHOLDER" />
    <add key="dotnet-public" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-public/nuget/v3/index.json" protocolVersion="3" />
    <add key="benchmark-dotnet-prerelease" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/benchmark-dotnet-prerelease/nuget/v3/index.json" />
    <add key="dotnet-libraries" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-libraries/nuget/v3/index.json" />
    <add key="dotnet-libraries-transport" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-libraries-transport/nuget/v3/index.json" />
    <add key="dotnet-eng" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-eng/nuget/v3/index.json" protocolVersion="3" />
    <add key="dotnet-tools" value="https://pkgs.dev.azure.com/dnceng/public/_packaging/dotnet-tools/nuget/v3/index.json" protocolVersion="3" />
  </packageSources>
  <activePackageSource>
    <add key="All" value="(Aggregate source)" />
  </activePackageSource>
  <disabledPackageSources>
    <add key="local" value="true" />
    <add key="nuget-only" value="true" />
    <add key="macios-devtools-local" value="true" />
  </disabledPackageSources>
</configuration>
